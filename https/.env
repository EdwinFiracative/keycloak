# Keycloak configuration
# keycloak admin credentials
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=*MDS1960sol#
# keycloak database configuration
KC_DB=postgres  #vendor of the database
KC_DB_USERNAME=admin
KC_DB_PASSWORD=*MDS1960sol#
KC_DB_URL=jdbc:postgresql://keycloak_postgres:5432/kckdb

# Keycloak server configuration for https connection with reverse proxy
KC_HOSTNAME=https://erp.proelectricos.com/keycloak
KC_HTTP_ENABLED=true
KC_PROXY_HEADERS=xforwarded

